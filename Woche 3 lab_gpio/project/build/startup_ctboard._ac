-Wa,armasm,--pd,"__UVISION_VERSION SETA 543" -Wa,armasm,--pd,"_RTE_ SETA 1"
-o ./build/startup_ctboard.o "RTE/Device/CT_Board_HS14_M0/startup_ctboard.s"