#include "lcd_io.h"
#include "hal_spi.h"
#include "hal_sbuf.h"

#define ACK_CHAR         (uint8_t)0x06
#define DC1_CHAR         (uint8_t)0x11
#define DC2_CHAR         (uint8_t)0x12
#define ESC_CHAR         (uint8_t)0x1B
#define ONE_CHAR         (uint8_t)0x01

#define NOTHING_RECEIVED (uint8_t)0
enum { SUCCESS = 0, ERRORCODE = 1 };

/* ------------------------------------------------------------------
 * -- Function prototypes
 * ------------------------------------------------------------------
 */
static uint8_t send_read_display_buffer_request(void);


/* ------------------------------------------------------------------
 * -- Function implementations
 * ------------------------------------------------------------------
 */

/*
 * according to description in header file
 */
void init_display_interface(void)
{
    hal_spi_init();
    hal_sbuf_init();
}


/*
 * according to description in header file
 */
uint8_t read_display_buffer(uint8_t *readBuffer)
{
    /// STUDENTS: To be programmed
    
    uint8_t len = 0;
    uint8_t i;
    uint8_t dummy;

    // Prüfe, ob das Display den SBUF Pin auf GND (0) gezogen hat
    // Wenn der Zustand nicht 0 ist, liegen keine Daten an
    if (hal_sbuf_get_state() != 0) { 
        return NOTHING_RECEIVED; 
    }

    // Sende die Anforderung und prüfe ob SUCCESS zurückkommt
    if (send_read_display_buffer_request() != SUCCESS) {
        return NOTHING_RECEIVED;
    }

    // Empfange das Datenpaket: <DC1> len Daten... bcc
    
    // Lese DC1
    dummy = hal_spi_read_write(0x00); 
    if (dummy != DC1_CHAR) {
        return NOTHING_RECEIVED;
    }

    // Lese Länge (len)
    len = hal_spi_read_write(0x00);

    // Lese die Nutzdaten in den übergebenen Array-Pointer
    for (i = 0; i < len; i++) {
        readBuffer[i] = hal_spi_read_write(0x00);
    }

    // Lese Prüfsumme bcc (wird eingelesen, aber hier nicht weiter verifiziert)
    dummy = hal_spi_read_write(0x00);

    // Gib die Anzahl der gelesenen Nutzdaten zurück
    return len;

    /// END: To be programmed
}


/*
 * according to description in header file
 */
uint8_t write_cmd_to_display(const uint8_t *cmdBuffer, uint8_t length)
{
    /// STUDENTS: To be programmed
    
    uint8_t bcc = 0;
    uint8_t rec_byte;
    uint8_t i;
    
    // Die Länge muss um 1 erhöht werden, da das ESC Zeichen dazu zählt
    uint8_t total_length = length + 1; 

    // 1. Sende Start-Steuerzeichen DC1 (0x11)
    hal_spi_read_write(DC1_CHAR);
    bcc += DC1_CHAR;

    // 2. Sende Länge der Nutzdaten (inkl. ESC)
    hal_spi_read_write(total_length);
    bcc += total_length;
    
    // 3. Sende ESC Zeichen (Befehlseinleitung)
    hal_spi_read_write(ESC_CHAR);
    bcc += ESC_CHAR;

    // 4. Sende die eigentlichen Nutzdaten (Befehlszeichenfolge)
    for (i = 0; i < length; i++) {
        hal_spi_read_write(cmdBuffer[i]);
        bcc += cmdBuffer[i];
    }

    // 5. Sende Prüfsumme bcc
    hal_spi_read_write(bcc);

    // 6. Empfange Bestätigungszeichen vom Display (Dummy-Byte 0x00 senden)
    rec_byte = hal_spi_read_write(0x00);

    // 7. Werte die Antwort aus
    if (rec_byte == ACK_CHAR) {
        return SUCCESS;
    } else {
        return ERRORCODE;
    }

    /// END: To be programmed
}


/*
 * Assemble and send a packet to trigger the reading of the display buffer
 * Uses the sequence "<DC2>, 0x01, 0x53, checksum" according to datasheet
 * Check if the ACK was sent by the lcd and return this
 */
static uint8_t send_read_display_buffer_request(void)
{
    /// STUDENTS: To be programmed
    
    uint8_t bcc = 0;
    uint8_t rec_byte;

    // Sende Befehlsfolge: DC2 (0x12), 0x01, 'S' (0x53)
    hal_spi_read_write(DC2_CHAR);
    bcc += DC2_CHAR;

    hal_spi_read_write(ONE_CHAR);
    bcc += ONE_CHAR;

    hal_spi_read_write('S');
    bcc += 'S';

    // Sende Prüfsumme bcc
    hal_spi_read_write(bcc);

    // Empfange Quittierung (ACK) vom Display (mit Senden von 0x00)
    rec_byte = hal_spi_read_write(0x00);

    // Prüfe auf ACK
    if (rec_byte == ACK_CHAR) {
        return SUCCESS;
    } else {
        return ERRORCODE;
    }

    /// END: To be programmed

}

